# ─────────────────────────────────────────────────────────────────────────────
# OS&E Cloud Inventory System — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
# Local (Docker Compose maps host 5433 → Postgres 5432 in container)
# postgresql://ose_user:ose_password@localhost:5433/ose_inventory
# Cloud (Railway/Render): provided in dashboard
DATABASE_URL=postgresql://ose_user:ose_password@localhost:5433/ose_inventory

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_SECURE_RANDOM_64_BYTE_HEX
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:4200

# ─── File Storage (AWS S3 or Cloudflare R2) ──────────────────────────────────
STORAGE_PROVIDER=local    # local | s3 | r2
AWS_REGION=us-east-1
AWS_BUCKET_NAME=ose-inventory
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_QUERIES=false          # Set to true to log all Prisma queries in dev
