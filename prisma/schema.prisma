// =============================================================================
// OS&E Cloud Inventory System — Prisma Schema
// Modules: M01–M15 | Architecture: Multi-tenant, Append-only Ledger, WAC
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STOREKEEPER
  DEPT_MANAGER
  COST_CONTROL
  FINANCE_MANAGER
  AUDITOR
  SECURITY_MANAGER
}

enum PlanType {
  BASIC
  PRO
  ENTERPRISE
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  SUSPENDED
}

enum MovementType {
  OPENING_BALANCE
  RECEIVE
  ISSUE
  TRANSFER
  TRANSFER_OUT
  TRANSFER_IN
  RETURN
  ADJUSTMENT
  BREAKAGE
  COUNT_ADJUSTMENT
  LOAN_WRITE_OFF
  GET_PASS_OUT
  GET_PASS_RETURN
}

enum GetPassType {
  TEMPORARY
  CATERING
  PERMANENT
}

enum GetPassStatus {
  DRAFT
  PENDING_DEPT
  PENDING_FINANCE
  PENDING_SECURITY
  APPROVED
  OUT
  PARTIALLY_RETURNED
  RETURNED
  CLOSED
  REJECTED
}

enum GetPassLineStatus {
  PENDING
  OUT
  PARTIALLY_RETURNED
  RETURNED
  LOST
}

enum MovementStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  VOID
  REJECTED
}

enum UnitType {
  BASE
  PURCHASE
  ISSUE
}

enum LocationType {
  MAIN_STORE
  OUTLET_STORE
  DEPARTMENT
}

enum ApprovalRequestType {
  ADJUSTMENT
  BREAKAGE
  COUNT_ADJUSTMENT
  GRN_IMPORT
  STORE_REQUISITION
  STOCK_REPORT
}

enum RequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_ISSUED
  FULLY_ISSUED
  CLOSED
  REJECTED
}

enum IssueStatus {
  DRAFT
  POSTED
}

enum TransferStatus {
  DRAFT
  SUBMITTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CLOSED
  REJECTED
}

enum GrnStatus {
  DRAFT
  VALIDATED
  PENDING_APPROVAL
  APPROVED
  POSTED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ImportStatus {
  PENDING
  VALIDATED
  COMPLETED
  FAILED
}

enum CountSessionStatus {
  OPEN
  SUBMITTED
  APPROVED
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SUBMIT
  POST
  VOID
  APPROVE
  REJECT
  IMPORT
  LOGIN
  LOGOUT
  CLOSE_PERIOD
  REOPEN_PERIOD
  LOCK_OB
  COUNT_APPROVE
  COUNT_REJECT
}

enum ReportType {
  SUMMARY
  DETAIL
  BREAKAGE
  OMC
  TRANSFERS
  AGING
}

// =============================================================================
// M01 — Tenants & Auth
// =============================================================================

model Tenant {
  id               String  @id @default(uuid()) @db.Uuid
  parentId         String? @db.Uuid
  name             String
  slug             String  @unique
  subscriptionTier String  @default("starter")
  logoUrl          String?
  address          String?
  phone            String?
  email            String?
  isActive         Boolean @default(true)
  hasBranches      Boolean @default(false)
  maxBranches      Int     @default(0)

  // --- License & Subscription Management ---
  planType         PlanType           @default(BASIC)
  subStatus        SubscriptionStatus @default(TRIAL)
  licenseStartDate DateTime           @default(now())
  licenseEndDate   DateTime?
  maxUsers         Int                @default(10)
  // -----------------------------------------

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent            Tenant?             @relation("TenantHierarchy", fields: [parentId], references: [id])
  children          Tenant[]            @relation("TenantHierarchy")
  memberships       TenantMember[]
  categories        Category[]
  subcategories     Subcategory[]
  departments       Department[]
  locations         Location[]
  units             Unit[]
  suppliers         Supplier[]
  items             Item[]
  inventoryLedger   InventoryLedger[]
  stockBalances     StockBalance[]
  movementDocuments MovementDocument[]
  approvalRequests  ApprovalRequest[]
  importSessions    ImportSession[]
  countSessions     StockCountSession[]
  auditLogs         AuditLog[]
  grnImports        GrnImport[]
  itemMappings      ItemMapping[]
  uomMappings       UomMapping[]
  vendorMappings    VendorMapping[]
  storeRequisitions StoreRequisition[]
  storeIssues       StoreIssue[]
  storeTransfers    StoreTransfer[]
  subscription      Subscription?
  tenantUsage       TenantUsage?
  periodCloses      PeriodClose[]
  tenantSettings    TenantSetting[]
  getPasses         GetPass[]
  savedStockReports SavedStockReport[]
  generatedReports  GeneratedReport[]
  superAdminLogs    SuperAdminLog[]     @relation("SuperAdminLogTenant")
  DocSequence       DocSequence[]

  @@index([parentId])
  @@index([hasBranches])
  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  department   String?
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships        TenantMember[]
  refreshTokens      RefreshToken[]
  locationUsers      LocationUser[]
  ledgerEntries      InventoryLedger[]   @relation("LedgerCreatedBy")
  movementsCreated   MovementDocument[]  @relation("MovementCreatedBy")
  approvalStepsActed ApprovalStep[]
  auditLogs          AuditLog[]
  importSessions     ImportSession[]
  countSessions      StockCountSession[]
  grnImported        GrnImport[]         @relation("GrnImportedBy")
  grnApproved        GrnImport[]         @relation("GrnApprovedBy")
  grnRejected        GrnImport[]         @relation("GrnRejectedBy")
  reqRequested       StoreRequisition[]  @relation("ReqRequestedBy")
  reqApproved        StoreRequisition[]  @relation("ReqApprovedBy")
  reqRejected        StoreRequisition[]  @relation("ReqRejectedBy")
  storeIssues        StoreIssue[]        @relation("IssueIssuedBy")
  trfRequested       StoreTransfer[]     @relation("TrfRequestedBy")
  trfApproved        StoreTransfer[]     @relation("TrfApprovedBy")
  trfRejected        StoreTransfer[]     @relation("TrfRejectedBy")
  trfReceived        StoreTransfer[]     @relation("TrfReceivedBy")
  adminLogs          SuperAdminLog[]     @relation("AdminLogUser")

  getPassesCreated  GetPass[]          @relation("GetPassCreatedBy")
  getPassesDeptApp  GetPass[]          @relation("GetPassDeptApprover")
  getPassesFinApp   GetPass[]          @relation("GetPassFinanceApprover")
  getPassesSecApp   GetPass[]          @relation("GetPassSecurityApprover")
  getPassesCheckout GetPass[]          @relation("GetPassCheckedOutBy")
  getPassesClosed   GetPass[]          @relation("GetPassClosedBy")
  getPassReturnsReg GetPassReturn[]    @relation("GetPassReturnRegisteredBy")
  getPassReturnsSec GetPassReturn[]    @relation("GetPassReturnSecurityBy")
  stockReports      SavedStockReport[]
  generatedReports  GeneratedReport[]  @relation("ReportGeneratedBy")

  @@map("users")
}

model TenantMember {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  userId    String   @db.Uuid
  departmentId String? @db.Uuid
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([departmentId])
  @@index([tenantId, departmentId])
  @@map("tenant_members")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================================================
// M03 — Categories & Subcategories
// =============================================================================

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  departmentId String?  @db.Uuid
  name         String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  department         Department?        @relation("DepartmentCategories", fields: [departmentId], references: [id])
  subcategories      Subcategory[]
  items              Item[]
  locationCategories LocationCategory[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([departmentId])
  @@map("categories")
}

model Subcategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  categoryId  String   @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  items    Item[]

  @@unique([tenantId, categoryId, name])
  @@index([tenantId])
  @@map("subcategories")
}

// =============================================================================
// M04 — Locations
// =============================================================================

// =============================================================================
// M04a — Departments
// =============================================================================

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  memberships      TenantMember[]
  locations        Location[]
  items            Item[]
  categories       Category[]        @relation("DepartmentCategories")
  generatedReports GeneratedReport[]
  GetPass          GetPass[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model Location {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  departmentId String?      @db.Uuid
  name         String
  type         LocationType @default(MAIN_STORE)
  description  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant                  Tenant                        @relation(fields: [tenantId], references: [id])
  department              Department?                   @relation(fields: [departmentId], references: [id])
  locationUsers           LocationUser[]
  locationCategories      LocationCategory[]
  stockBalances           StockBalance[]
  ledgerEntries           InventoryLedger[]
  countSessions           StockCountSession[]
  movementLines           MovementLine[]
  grnImports              GrnImport[]
  storeRequisitions       StoreRequisition[]
  transfersOut            StoreTransfer[]               @relation("TransferSource")
  transfersIn             StoreTransfer[]               @relation("TransferDest")
  defaultItems            Item[]                        @relation("ItemDefaultStore")
  getPassLines            GetPassLine[]
  stockReports            SavedStockReport[]
  savedReportLocationQtys SavedStockReportLocationQty[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([departmentId])
  @@map("locations")
}

model LocationCategory {
  id         String @id @default(uuid()) @db.Uuid
  locationId String @db.Uuid
  categoryId String @db.Uuid

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([locationId, categoryId])
  @@map("location_categories")
}

model LocationUser {
  id         String @id @default(uuid()) @db.Uuid
  locationId String @db.Uuid
  userId     String @db.Uuid

  location Location @relation(fields: [locationId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([locationId, userId])
  @@map("location_users")
}

// =============================================================================
// M05 — Units of Measure
// =============================================================================

model Unit {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  abbreviation String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  itemUnits        ItemUnit[]
  requisitionLines StoreRequisitionLine[]
  issueLines       StoreIssueLine[]
  transferLines    StoreTransferLine[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("units")
}

model ItemUnit {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  itemId         String   @db.Uuid
  unitId         String   @db.Uuid
  unitType       UnitType
  conversionRate Decimal  @default(1) @db.Decimal(15, 6)
  isDefault      Boolean  @default(false)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([itemId, unitType])
  @@index([tenantId])
  @@map("item_units")
}

// =============================================================================
// M06 — Suppliers
// =============================================================================

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  items      Item[]
  grnImports GrnImport[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("suppliers")
}

// =============================================================================
// M02 — Item Master
// =============================================================================

model Item {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  name           String
  description    String?
  departmentId   String?  @db.Uuid
  categoryId     String?  @db.Uuid
  subcategoryId  String?  @db.Uuid
  supplierId     String?  @db.Uuid
  defaultStoreId String?  @db.Uuid
  barcode        String?
  code           String?
  unitPrice      Decimal  @default(0) @db.Decimal(15, 4)
  imageUrl       String?
  reorderPoint   Int      @default(0)
  reorderQty     Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  department       Department?            @relation(fields: [departmentId], references: [id])
  category         Category?              @relation(fields: [categoryId], references: [id])
  subcategory      Subcategory?           @relation(fields: [subcategoryId], references: [id])
  supplier         Supplier?              @relation(fields: [supplierId], references: [id])
  defaultStore     Location?              @relation("ItemDefaultStore", fields: [defaultStoreId], references: [id])
  itemUnits        ItemUnit[]
  stockBalances    StockBalance[]
  ledgerEntries    InventoryLedger[]
  movementLines    MovementLine[]
  countLines       StockCountLine[]
  requisitionLines StoreRequisitionLine[]
  issueLines       StoreIssueLine[]
  transferLines    StoreTransferLine[]
  getPassLines     GetPassLine[]
  stockReportLines SavedStockReportLine[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, departmentId])
  @@map("items")
}

// =============================================================================
// M08 — Inventory Ledger (Append-only) + Stock Balances
// =============================================================================

model InventoryLedger {
  id               String       @id @default(uuid()) @db.Uuid
  tenantId         String       @db.Uuid
  itemId           String       @db.Uuid
  locationId       String       @db.Uuid
  movementType     MovementType
  qtyIn            Decimal      @default(0) @db.Decimal(15, 4)
  qtyOut           Decimal      @default(0) @db.Decimal(15, 4)
  unitCost         Decimal      @default(0) @db.Decimal(15, 4)
  totalValue       Decimal      @default(0) @db.Decimal(15, 4)
  referenceType    String? // 'GRN', 'ISSUE_NOTE', 'TRANSFER', etc.
  referenceId      String?      @db.Uuid
  referenceNo      String?
  requiresApproval Boolean      @default(false)
  approvalId       String?      @db.Uuid
  notes            String?
  createdBy        String       @db.Uuid
  createdAt        DateTime     @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  item            Item             @relation(fields: [itemId], references: [id])
  location        Location         @relation(fields: [locationId], references: [id])
  createdByUser   User             @relation("LedgerCreatedBy", fields: [createdBy], references: [id])
  approvalRequest ApprovalRequest? @relation(fields: [approvalId], references: [id])

  @@index([tenantId, itemId])
  @@index([tenantId, locationId])
  @@index([tenantId, createdAt])
  @@index([tenantId, movementType])
  @@index([tenantId, movementType, createdAt])
  @@index([tenantId, locationId, itemId])
  @@index([tenantId, locationId, itemId, createdAt])
  @@index([tenantId, referenceId])
  @@map("inventory_ledger")
}

model StockBalance {
  tenantId     String   @db.Uuid
  itemId       String   @db.Uuid
  locationId   String   @db.Uuid
  qtyOnHand    Decimal  @default(0) @db.Decimal(15, 4)
  wacUnitCost  Decimal  @default(0) @db.Decimal(15, 4)
  minQty       Decimal  @default(0) @db.Decimal(15, 4)
  maxQty       Decimal  @default(0) @db.Decimal(15, 4)
  reorderPoint Decimal  @default(0) @db.Decimal(15, 4)
  lastUpdated  DateTime @default(now()) @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@id([tenantId, itemId, locationId])
  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([tenantId, itemId])
  @@map("stock_balances")
}

// =============================================================================
// M09 / M10 — Movement Documents & Lines
// =============================================================================

model MovementDocument {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @db.Uuid
  documentNo       String
  movementType     MovementType
  status           MovementStatus @default(DRAFT)
  sourceLocationId String?        @db.Uuid
  destLocationId   String?        @db.Uuid
  documentDate     DateTime       @default(now())
  supplierId       String?        @db.Uuid
  department       String?
  reason           String? // for ADJUSTMENT, BREAKAGE
  notes            String?
  attachmentUrl    String?
  createdBy        String         @db.Uuid
  postedAt         DateTime?
  voidedAt         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  createdByUser    User                @relation("MovementCreatedBy", fields: [createdBy], references: [id])
  approvalRequests ApprovalRequest[]
  sessions         StockCountSession[]
  lines            MovementLine[]

  @@unique([tenantId, documentNo])
  @@index([tenantId, movementType])
  @@index([tenantId, movementType, documentDate])
  @@index([tenantId, status])
  @@map("movement_documents")
}

model MovementLine {
  id            String  @id @default(uuid()) @db.Uuid
  documentId    String  @db.Uuid
  itemId        String  @db.Uuid
  locationId    String  @db.Uuid
  unitId        String? @db.Uuid
  qtyRequested  Decimal @db.Decimal(15, 4)
  qtyInBaseUnit Decimal @db.Decimal(15, 4)
  unitCost      Decimal @default(0) @db.Decimal(15, 4)
  totalValue    Decimal @default(0) @db.Decimal(15, 4)
  notes         String?

  document MovementDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  item     Item             @relation(fields: [itemId], references: [id])
  location Location         @relation(fields: [locationId], references: [id])

  @@index([documentId])
  @@map("movement_lines")
}

// =============================================================================
// M11 — Approval Workflow Engine
// =============================================================================

model ApprovalRequest {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @db.Uuid
  requestType ApprovalRequestType
  status      ApprovalStatus      @default(PENDING)
  documentId  String?             @unique @db.Uuid
  currentStep Int                 @default(0)
  totalSteps  Int
  createdBy   String              @db.Uuid
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  document          MovementDocument?  @relation(fields: [documentId], references: [id])
  steps             ApprovalStep[]
  ledgerEntries     InventoryLedger[]
  StockCountSession StockCountSession?
  SavedStockReport  SavedStockReport?

  @@index([tenantId, status])
  @@map("approval_requests")
}

model ApprovalStep {
  id           String             @id @default(uuid()) @db.Uuid
  requestId    String             @db.Uuid
  stepNumber   Int
  requiredRole UserRole
  status       ApprovalStepStatus @default(PENDING)
  actedBy      String?            @db.Uuid
  actedAt      DateTime?
  comment      String?

  request     ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actedByUser User?           @relation(fields: [actedBy], references: [id])

  @@unique([requestId, stepNumber])
  @@map("approval_steps")
}

// =============================================================================
// M07 — Opening Balance Import
// =============================================================================

model ImportSession {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid
  filename    String
  status      ImportStatus @default(PENDING)
  totalRows   Int          @default(0)
  validRows   Int          @default(0)
  errorRows   Int          @default(0)
  warningRows Int          @default(0)
  columnMap   Json?
  importedBy  String       @db.Uuid
  importedAt  DateTime?
  createdAt   DateTime     @default(now())

  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  importedByUser User        @relation(fields: [importedBy], references: [id])
  rows           ImportRow[]

  @@index([tenantId])
  @@map("import_sessions")
}

model ImportRow {
  id         String @id @default(uuid()) @db.Uuid
  sessionId  String @db.Uuid
  rowNumber  Int
  rawData    Json
  mappedData Json?
  status     String @default("PENDING") // VALID | WARNING | ERROR
  errors     Json?
  warnings   Json?

  session ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("import_rows")
}

// =============================================================================
// M10 — Stock Count Sessions
// =============================================================================

model StockCountSession {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @db.Uuid
  locationId String         @db.Uuid
  sessionNo  String
  countDate  DateTime       @default(now())
  status     MovementStatus @default(DRAFT)
  notes      String?
  snapshotAt DateTime       @default(now())
  postedAt   DateTime?
  createdBy  String         @db.Uuid
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  location           Location          @relation(fields: [locationId], references: [id])
  createdByUser      User              @relation(fields: [createdBy], references: [id])
  lines              StockCountLine[]
  approvalRequest    ApprovalRequest?  @relation(fields: [approvalRequestId], references: [id])
  approvalRequestId  String?           @unique @db.Uuid
  MovementDocument   MovementDocument? @relation(fields: [movementDocumentId], references: [id])
  movementDocumentId String?           @db.Uuid

  @@unique([tenantId, sessionNo])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status, snapshotAt])
  @@map("stock_count_sessions")
}

model StockCountLine {
  id            String   @id @default(uuid()) @db.Uuid
  sessionId     String   @db.Uuid
  itemId        String   @db.Uuid
  bookQty       Decimal  @db.Decimal(15, 4)
  qtyOnLoan     Decimal  @default(0) @db.Decimal(15, 4)
  countedQty    Decimal? @db.Decimal(15, 4)
  varianceQty   Decimal? @db.Decimal(15, 4)
  wacUnitCost   Decimal  @db.Decimal(15, 4)
  varianceValue Decimal? @db.Decimal(15, 4)
  notes         String?

  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item              @relation(fields: [itemId], references: [id])

  @@unique([sessionId, itemId])
  @@index([sessionId])
  @@map("stock_count_lines")
}

// =============================================================================
// Period Close (Year/Month End) & Balance Snapshots
// =============================================================================

model PeriodClose {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  year      Int
  month     Int? // null = annual close, 1-12 = monthly
  status    String    @default("OPEN") // OPEN | CLOSED
  closedAt  DateTime?
  closedBy  String?   @db.Uuid
  notes     String?
  createdAt DateTime  @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  snapshots PeriodSnapshot[]

  @@unique([tenantId, year, month])
  @@index([tenantId])
  @@map("period_closes")
}

model PeriodSnapshot {
  id            String  @id @default(uuid()) @db.Uuid
  periodCloseId String  @db.Uuid
  itemId        String  @db.Uuid
  locationId    String  @db.Uuid
  closingQty    Decimal @db.Decimal(15, 4)
  closingValue  Decimal @db.Decimal(15, 4)
  wacUnitCost   Decimal @db.Decimal(15, 4)

  periodClose PeriodClose @relation(fields: [periodCloseId], references: [id], onDelete: Cascade)

  @@unique([periodCloseId, itemId, locationId])
  @@index([periodCloseId])
  @@map("period_snapshots")
}

// =============================================================================
// M14 — Audit Log (Immutable)
// =============================================================================

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @db.Uuid
  entityType  String
  entityId    String
  action      AuditAction
  changedBy   String      @db.Uuid
  changedAt   DateTime    @default(now())
  beforeValue Json?
  afterValue  Json?
  note        String?
  ipAddress   String?
  userAgent   String?

  tenant        Tenant @relation(fields: [tenantId], references: [id])
  changedByUser User   @relation(fields: [changedBy], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, changedAt])
  @@index([tenantId, changedBy])
  @@map("audit_log")
}

// Document Numbering — atomic per-tenant per-prefix per-year sequence
model DocSequence {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  prefix   String // GRN, ISS, TRF, BRK, ADJ, OB, CNT, CLS
  year     Int
  lastSeq  Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, prefix, year])
  @@map("doc_sequence")
}

// =============================================================================
// M04-GRN — FutureLog GRN Import & Approval Gate
// =============================================================================

model GrnImport {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @db.Uuid
  grnNumber          String
  // Vendor: hard-matched to internal Supplier. Null until matched via VendorMapping.
  vendorId           String?   @db.Uuid
  vendorNameSnapshot String // Raw vendor name from FutureLog (for display)
  locationId         String    @db.Uuid
  receivingDate      DateTime
  pdfAttachmentUrl   String // Mandatory — enforced in service before status change
  status             GrnStatus @default(DRAFT)
  rejectionReason    String?
  notes              String?
  importedBy         String    @db.Uuid
  approvedBy         String?   @db.Uuid
  rejectedBy         String?   @db.Uuid
  postedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  vendor         Supplier? @relation(fields: [vendorId], references: [id])
  location       Location  @relation(fields: [locationId], references: [id])
  importedByUser User      @relation("GrnImportedBy", fields: [importedBy], references: [id])
  approvedByUser User?     @relation("GrnApprovedBy", fields: [approvedBy], references: [id])
  rejectedByUser User?     @relation("GrnRejectedBy", fields: [rejectedBy], references: [id])
  lines          GrnLine[]

  @@unique([tenantId, grnNumber])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([tenantId, locationId])
  @@map("grn_imports")
}

model GrnLine {
  id                   String  @id @default(uuid()) @db.Uuid
  grnImportId          String  @db.Uuid
  // FutureLog source data
  futurelogItemCode    String
  futurelogDescription String
  futurelogUom         String
  orderedQty           Decimal @db.Decimal(15, 4) // Stored for reference only — NEVER posted
  receivedQty          Decimal @db.Decimal(15, 4) // The only qty that flows to ledger
  unitPrice            Decimal @db.Decimal(15, 4)
  // Internal mapping — nullable until mapped
  internalItemId       String? @db.Uuid
  internalUomId        String? @db.Uuid
  conversionFactor     Decimal @default(1) @db.Decimal(15, 6) // Mandatory when UOMs differ
  qtyInBaseUnit        Decimal @default(0) @db.Decimal(15, 4) // receivedQty × conversionFactor
  isMapped             Boolean @default(false)

  grnImport GrnImport @relation(fields: [grnImportId], references: [id], onDelete: Cascade)

  @@index([grnImportId])
  @@index([grnImportId, isMapped])
  @@map("grn_lines")
}

model ItemMapping {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  futurelogItemCode String
  futurelogItemName String
  internalItemId    String   @db.Uuid
  createdBy         String   @db.Uuid
  updatedBy         String   @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, futurelogItemCode])
  @@index([tenantId])
  @@map("item_mappings")
}

model UomMapping {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  futurelogUom     String
  internalUomId    String   @db.Uuid
  conversionFactor Decimal  @default(1) @db.Decimal(15, 6)
  createdBy        String   @db.Uuid
  updatedBy        String   @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, futurelogUom])
  @@index([tenantId])
  @@map("uom_mappings")
}

model VendorMapping {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid
  futurelogVendorName String // Raw name from FutureLog (normalized/trimmed)
  internalSupplierId  String   @db.Uuid
  createdBy           String   @db.Uuid
  updatedBy           String   @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, futurelogVendorName])
  @@index([tenantId])
  @@map("vendor_mappings")
}

// =============================================================================
// M05-REQ — Store Requisition & Controlled Issue Gate
// =============================================================================

model StoreRequisition {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @db.Uuid
  requisitionNo   String // Auto: REQ-YYYYMM-NNNN
  departmentName  String // Free-text: Kitchen, HK, Engineering …
  locationId      String            @db.Uuid // Issuing store
  requestedBy     String            @db.Uuid
  approvedBy      String?           @db.Uuid
  rejectedBy      String?           @db.Uuid
  requestDate     DateTime          @default(now())
  requiredBy      DateTime? // Requested delivery date (optional)
  status          RequisitionStatus @default(DRAFT)
  remarks         String?
  rejectionReason String?
  approvedAt      DateTime?
  fullyIssuedAt   DateTime?
  closedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  location        Location               @relation(fields: [locationId], references: [id])
  requestedByUser User                   @relation("ReqRequestedBy", fields: [requestedBy], references: [id])
  approvedByUser  User?                  @relation("ReqApprovedBy", fields: [approvedBy], references: [id])
  rejectedByUser  User?                  @relation("ReqRejectedBy", fields: [rejectedBy], references: [id])
  lines           StoreRequisitionLine[]
  issues          StoreIssue[]

  @@unique([tenantId, requisitionNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, locationId])
  @@map("store_requisitions")
}

model StoreRequisitionLine {
  id             String  @id @default(uuid()) @db.Uuid
  requisitionId  String  @db.Uuid
  itemId         String  @db.Uuid
  uomId          String  @db.Uuid
  requestedQty   Decimal @db.Decimal(15, 4)
  totalIssuedQty Decimal @default(0) @db.Decimal(15, 4) // Cumulative across all issues
  notes          String?

  requisition StoreRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  item        Item             @relation(fields: [itemId], references: [id])
  uom         Unit             @relation(fields: [uomId], references: [id])
  issueLines  StoreIssueLine[]

  @@index([requisitionId])
  @@map("store_requisition_lines")
}

model StoreIssue {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @db.Uuid
  issueNo       String // Auto: ISS-YYYYMM-NNNN
  requisitionId String      @db.Uuid
  issueDate     DateTime    @default(now())
  issuedBy      String      @db.Uuid
  status        IssueStatus @default(DRAFT)
  notes         String?
  attachmentUrl String?
  postedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  requisition  StoreRequisition @relation(fields: [requisitionId], references: [id])
  issuedByUser User             @relation("IssueIssuedBy", fields: [issuedBy], references: [id])
  lines        StoreIssueLine[]

  @@unique([tenantId, issueNo])
  @@index([tenantId])
  @@index([tenantId, requisitionId])
  @@map("store_issues")
}

model StoreIssueLine {
  id                String  @id @default(uuid()) @db.Uuid
  issueId           String  @db.Uuid
  requisitionLineId String  @db.Uuid
  itemId            String  @db.Uuid // Denormalized for query speed
  uomId             String  @db.Uuid
  issuedQty         Decimal @db.Decimal(15, 4)
  unitCost          Decimal @default(0) @db.Decimal(15, 4) // WAC at time of posting
  totalValue        Decimal @default(0) @db.Decimal(15, 4)

  issue           StoreIssue           @relation(fields: [issueId], references: [id], onDelete: Cascade)
  requisitionLine StoreRequisitionLine @relation(fields: [requisitionLineId], references: [id])
  item            Item                 @relation(fields: [itemId], references: [id])
  uom             Unit                 @relation(fields: [uomId], references: [id])

  @@index([issueId])
  @@index([requisitionLineId])
  @@map("store_issue_lines")
}

// =============================================================================
// M06-TRF — Inter-Store Transfer Control Gate
// =============================================================================

model StoreTransfer {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @db.Uuid
  transferNo       String // Auto: TRF-YYYYMM-NNNN
  sourceLocationId String         @db.Uuid // Sending store
  destLocationId   String         @db.Uuid // Receiving store
  requestedBy      String         @db.Uuid
  approvedBy       String?        @db.Uuid
  rejectedBy       String?        @db.Uuid
  receivedBy       String?        @db.Uuid
  transferDate     DateTime       @default(now())
  requiredBy       DateTime?
  status           TransferStatus @default(DRAFT)
  reason           String?
  rejectionReason  String?
  notes            String?
  approvedAt       DateTime?
  dispatchedAt     DateTime? // Set when status → IN_TRANSIT
  receivedAt       DateTime? // Set when destination confirms RECEIVED
  closedAt         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  sourceLocation  Location            @relation("TransferSource", fields: [sourceLocationId], references: [id])
  destLocation    Location            @relation("TransferDest", fields: [destLocationId], references: [id])
  requestedByUser User                @relation("TrfRequestedBy", fields: [requestedBy], references: [id])
  approvedByUser  User?               @relation("TrfApprovedBy", fields: [approvedBy], references: [id])
  rejectedByUser  User?               @relation("TrfRejectedBy", fields: [rejectedBy], references: [id])
  receivedByUser  User?               @relation("TrfReceivedBy", fields: [receivedBy], references: [id])
  lines           StoreTransferLine[]

  @@unique([tenantId, transferNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, sourceLocationId])
  @@index([tenantId, destLocationId])
  @@map("store_transfers")
}

model StoreTransferLine {
  id           String   @id @default(uuid()) @db.Uuid
  transferId   String   @db.Uuid
  itemId       String   @db.Uuid
  uomId        String   @db.Uuid
  requestedQty Decimal  @db.Decimal(15, 4)
  receivedQty  Decimal? @db.Decimal(15, 4) // Confirmed at destination (partial ok)
  unitCost     Decimal  @default(0) @db.Decimal(15, 4) // WAC at time of OUT posting
  totalValue   Decimal  @default(0) @db.Decimal(15, 4)
  notes        String?

  transfer StoreTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     Item          @relation(fields: [itemId], references: [id])
  uom      Unit          @relation(fields: [uomId], references: [id])

  @@index([transferId])
  @@map("store_transfer_lines")
}

// =============================================================================
// SaaS Phase 1 — Subscription, Usage Tracking, Super Admin Audit
// =============================================================================

model Subscription {
  id                  String             @id @default(uuid()) @db.Uuid
  tenantId            String             @unique @db.Uuid
  planType            PlanType           @default(BASIC)
  status              SubscriptionStatus @default(TRIAL)
  startDate           DateTime           @default(now())
  endDate             DateTime?
  trialEndsAt         DateTime?
  maxUsers            Int                @default(5)
  maxStores           Int                @default(2)
  maxDepartments      Int                @default(3)
  maxMonthlyMovements Int                @default(500)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

model TenantUsage {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @unique @db.Uuid
  totalUsers         Int       @default(0)
  totalActiveStores  Int       @default(0)
  movementsThisMonth Int       @default(0)
  movementsResetAt   DateTime  @default(now())
  storageBytes       BigInt    @default(0)
  lastActivityAt     DateTime?
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_usage")
}

model SuperAdminLog {
  id             String   @id @default(uuid()) @db.Uuid
  adminUserId    String   @db.Uuid
  action         String
  targetTenantId String?  @db.Uuid
  details        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  targetTenant Tenant? @relation("SuperAdminLogTenant", fields: [targetTenantId], references: [id])
  adminUser    User    @relation("AdminLogUser", fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([targetTenantId])
  @@index([createdAt])
  @@map("super_admin_logs")
}

// =============================================================================
// Tenant Settings (Key-Value Store)
// =============================================================================

model TenantSetting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String
  value     String
  updatedBy String?  @db.Uuid
  reason    String?
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_settings")
}

// =============================================================================
// M11 — Get Pass (Document Workflow for Assets Leaving Property)
// =============================================================================

model GetPass {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @db.Uuid
  passNo             String
  transferType       GetPassType
  departmentId       String?       @db.Uuid
  borrowingEntity    String
  expectedReturnDate DateTime?
  status             GetPassStatus @default(DRAFT)

  // Approvals
  deptApprovedBy     String?   @db.Uuid
  deptApprovedAt     DateTime?
  financeApprovedBy  String?   @db.Uuid
  financeApprovedAt  DateTime?
  securityApprovedBy String?   @db.Uuid
  securityApprovedAt DateTime?

  // Lifecycle
  checkedOutBy String?   @db.Uuid
  checkedOutAt DateTime?
  closedBy     String?   @db.Uuid
  closedAt     DateTime?

  reason    String?
  notes     String?
  createdBy String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  department       Department? @relation(fields: [departmentId], references: [id])
  createdByUser    User        @relation("GetPassCreatedBy", fields: [createdBy], references: [id])
  deptApprover     User?       @relation("GetPassDeptApprover", fields: [deptApprovedBy], references: [id])
  financeApprover  User?       @relation("GetPassFinanceApprover", fields: [financeApprovedBy], references: [id])
  securityApprover User?       @relation("GetPassSecurityApprover", fields: [securityApprovedBy], references: [id])
  checkoutUser     User?       @relation("GetPassCheckedOutBy", fields: [checkedOutBy], references: [id])
  closingUser      User?       @relation("GetPassClosedBy", fields: [closedBy], references: [id])

  lines GetPassLine[]

  @@unique([tenantId, passNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([departmentId])
  @@map("get_passes")
}

model GetPassLine {
  id           String            @id @default(uuid()) @db.Uuid
  getPassId    String            @db.Uuid
  itemId       String            @db.Uuid
  locationId   String            @db.Uuid
  qty          Decimal           @db.Decimal(15, 4)
  qtyReturned  Decimal           @default(0) @db.Decimal(15, 4)
  unitCost     Decimal           @default(0) @db.Decimal(15, 4) // WAC at OUT
  conditionOut String?
  status       GetPassLineStatus @default(PENDING)
  notes        String?

  getPass  GetPass         @relation(fields: [getPassId], references: [id], onDelete: Cascade)
  item     Item            @relation(fields: [itemId], references: [id])
  location Location        @relation(fields: [locationId], references: [id])
  returns  GetPassReturn[]

  @@index([getPassId])
  @@index([itemId])
  @@index([locationId])
  @@map("get_pass_lines")
}

model GetPassReturn {
  id                 String   @id @default(uuid()) @db.Uuid
  getPassLineId      String   @db.Uuid
  qtyReturned        Decimal  @db.Decimal(15, 4)
  conditionIn        String?
  returnDate         DateTime @default(now())
  registeredBy       String   @db.Uuid
  securityVerifiedBy String?  @db.Uuid
  notes              String?

  getPassLine      GetPassLine @relation(fields: [getPassLineId], references: [id], onDelete: Cascade)
  registeredByUser User        @relation("GetPassReturnRegisteredBy", fields: [registeredBy], references: [id])
  securityUser     User?       @relation("GetPassReturnSecurityBy", fields: [securityVerifiedBy], references: [id])

  @@index([getPassLineId])
  @@index([returnDate])
  @@map("get_pass_returns")
}

// =============================================================================
// Saved Stock Reports (For Approval Workflow)
// =============================================================================

model SavedStockReport {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  reportNo          String
  locationId        String         @db.Uuid
  status            MovementStatus @default(DRAFT)
  dateGenerated     DateTime       @default(now())
  totalValue        Decimal        @default(0) @db.Decimal(15, 4)
  notes             String?
  createdBy         String         @db.Uuid
  approvalRequestId String?        @unique @db.Uuid
  postedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  location        Location               @relation(fields: [locationId], references: [id])
  createdByUser   User                   @relation(fields: [createdBy], references: [id])
  approvalRequest ApprovalRequest?       @relation(fields: [approvalRequestId], references: [id])
  lines           SavedStockReportLine[]

  @@unique([tenantId, reportNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, locationId])
  @@map("saved_stock_reports")
}

model SavedStockReportLine {
  id           String  @id @default(uuid()) @db.Uuid
  reportId     String  @db.Uuid
  itemId       String  @db.Uuid
  openingQty   Decimal @default(0) @db.Decimal(15, 4)
  openingValue Decimal @default(0) @db.Decimal(15, 4)
  inwardQty    Decimal @default(0) @db.Decimal(15, 4)
  inwardValue  Decimal @default(0) @db.Decimal(15, 4)
  outwardQty   Decimal @default(0) @db.Decimal(15, 4)
  outwardValue Decimal @default(0) @db.Decimal(15, 4)
  closingQty   Decimal @default(0) @db.Decimal(15, 4)
  closingValue Decimal @default(0) @db.Decimal(15, 4)
  outOnPassQty Decimal @default(0) @db.Decimal(15, 4)
  grnQty       Decimal @default(0) @db.Decimal(15, 4)
  grnValue     Decimal @default(0) @db.Decimal(15, 4)
  breakages    Decimal @default(0) @db.Decimal(15, 4)

  report       SavedStockReport              @relation(fields: [reportId], references: [id], onDelete: Cascade)
  item         Item                          @relation(fields: [itemId], references: [id])
  locationQtys SavedStockReportLocationQty[]

  @@index([reportId])
  @@map("saved_stock_report_lines")
}

model SavedStockReportLocationQty {
  id          String   @id @default(uuid()) @db.Uuid
  lineId      String   @db.Uuid
  locationId  String   @db.Uuid
  bookQty     Decimal  @default(0) @db.Decimal(15, 4)
  countedQty  Decimal? @db.Decimal(15, 4)
  varianceQty Decimal  @default(0) @db.Decimal(15, 4)

  line     SavedStockReportLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  location Location             @relation(fields: [locationId], references: [id])

  @@index([lineId])
  @@index([locationId])
  @@map("saved_stock_report_location_qtys")
}

// =============================================================================
// Generated Reports (History for Summary, Detail, Breakage, OMC, Transfers, Aging)
// =============================================================================

model GeneratedReport {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  reportType   ReportType
  reportName   String
  departmentId String?    @db.Uuid
  startDate    DateTime?
  endDate      DateTime?
  data         Json
  generatedBy  String     @db.Uuid
  createdAt    DateTime   @default(now())

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  department      Department? @relation(fields: [departmentId], references: [id])
  generatedByUser User        @relation("ReportGeneratedBy", fields: [generatedBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, reportType])
  @@index([tenantId, departmentId])
  @@map("generated_reports")
}
